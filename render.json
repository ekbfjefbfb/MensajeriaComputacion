{
  "version": "1.0",
  "services": [
    {
      "name": "chat-demo",
      "type": "web",
      "env": "python",
      "buildCommand": "pip install -r requirements.txt",
      "startCommand": "gunicorn -k eventlet -w 1 app:app --bind 0.0.0.0:$PORT",
      "envVars": [
        {
          "key": "SECRET_KEY",
          "generateValue": true
        },
        {
          "key": "PORT",
          "value": "10000"
        }
      ]
    }
  ]
}
